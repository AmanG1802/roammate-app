POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=roammate
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here

# Google Maps
# GOOGLE_MAPS_MOCK=true: backend never calls Google, frontend skips the JS SDK.
# GOOGLE_MAPS_API_KEY is only consulted when GOOGLE_MAPS_MOCK=false.
GOOGLE_MAPS_MOCK=true
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
# GOOGLE_MAPS_API_VERSION: "v1" = legacy Places + Directions (cheaper Find Place),
# "v2" = Places API New + Routes API.  Default is v1.
GOOGLE_MAPS_API_VERSION=v1
# Feature flags — toggle to reduce API cost at the expense of UI richness.
# GOOGLE_MAPS_FETCH_PHOTOS=false removes photos from field mask (saves 7K Enterprise SKU).
# GOOGLE_MAPS_FETCH_RATING=false removes rating/price_level (upgrades free cap from 35K to 70K).
GOOGLE_MAPS_FETCH_PHOTOS=true
GOOGLE_MAPS_FETCH_RATING=true

# Apple Maps Server API (iOS enrichment)
# When enabled, iOS clients get place data from Apple instead of Google.
# Requires a MapKit JS key from https://developer.apple.com/account/resources/authkeys
APPLE_MAPS_ENABLED=false
APPLE_MAPS_TEAM_ID=your_apple_team_id_here
APPLE_MAPS_KEY_ID=your_apple_key_id_here
# Path to the .p8 private key file. Use container path when running in Docker.
APPLE_MAPS_PRIVATE_KEY_PATH=/app/keys/AuthKey_XXXXXXXXXX.p8

# LLM runtime config
# LLM_PROVIDER: openai | claude | gemini
# LLM_MODEL examples:
#   openai  -> gpt-4o-mini, gpt-4o
#   claude  -> claude-3-5-sonnet-latest, claude-3-5-haiku-latest
#   gemini  -> gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Backend JWT secret — change this to a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret-key

# ── Auth (access + refresh tokens, cookies) ─────────────────────────────────
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
# In prod, set COOKIE_DOMAIN=.roammate.app and COOKIE_SECURE=true
COOKIE_DOMAIN=
COOKIE_SECURE=false
PUBLIC_WEB_URL=http://localhost:3000

# Transactional email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Roammate <auth@roammate.app>

# Google OAuth (one client ID per platform)
GOOGLE_OAUTH_CLIENT_ID_WEB=
GOOGLE_OAUTH_CLIENT_ID_IOS=

# Sign in with Apple
APPLE_SIGNIN_BUNDLE_ID=com.roammate.app
APPLE_SIGNIN_SERVICE_ID=
APPLE_SIGNIN_TEAM_ID=

# Web env vars (frontend reads NEXT_PUBLIC_*; mirror what's needed)
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_APPLE_SIGNIN_SERVICE_ID=
NEXT_PUBLIC_APPLE_SIGNIN_REDIRECT_URI=http://localhost:3000/auth/callback/apple

# Frontend (Next.js) — set in frontend/.env.local for local dev
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Mirror of backend GOOGLE_MAPS_MOCK — when true, the frontend skips the Google
# Maps JS SDK and renders a stylized mock pane instead.
NEXT_PUBLIC_GOOGLE_MAPS_MOCK=true
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
# Mirror of backend enrichment flags — controls whether the UI renders photos/rating.
NEXT_PUBLIC_GOOGLE_MAPS_FETCH_PHOTOS=true
NEXT_PUBLIC_GOOGLE_MAPS_FETCH_RATING=true

# ── Subscription / billing ──────────────────────────────────────────────────
# Razorpay (India web/Android). Create the recurring monthly plan in the
# Razorpay dashboard and paste its plan_id below. Use test keys for dev.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_PLAN_ID_MONTHLY=plan_xxxxxxxxxxxx
# Frontend reads the public key id to open Razorpay Checkout.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Apple IAP (iOS). Configure the auto-renewable subscription product in
# App Store Connect and set the bundle id / product id here.
APPLE_BUNDLE_ID=com.roammate.app
APPLE_IAP_PRODUCT_ID_MONTHLY=com.roammate.app.plus.monthly
# Optional: App Store Server API credentials for renewal lookups & SSN V2.
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_USE_SANDBOX=true

# Free-tier caps (Plus is unlimited). Adjust here if you ever want to tweak.
FREE_ACTIVE_TRIPS_CAP=2
FREE_BRAINSTORM_MONTHLY_CAP=15
PLUS_MONTHLY_PRICE_INR=149
