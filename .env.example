POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=roammate
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# LLM runtime config
# LLM_PROVIDER: openai | claude | gemini
# LLM_MODEL examples:
#   openai  -> gpt-4o-mini, gpt-4o
#   claude  -> claude-3-5-sonnet-latest, claude-3-5-haiku-latest
#   gemini  -> gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Backend JWT secret — change this to a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret-key

# Frontend (Next.js) — set in frontend/.env.local for local dev
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
