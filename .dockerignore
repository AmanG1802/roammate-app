# ── Version control ────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Environment & Secrets ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ── Next.js / Node ─────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/npm-debug.log*

# ── Tests (not needed at runtime) ──────────────────────────────────────────────
tests/
backend/tests/
frontend/tests/

# ── Docs & Dev tooling ─────────────────────────────────────────────────────────
*.md
.idea/
.vscode/

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misc ───────────────────────────────────────────────────────────────────────
*.log
*.sqlite
docker-compose.override.yml
